// Monica Kelly Criterion Momentum Indicator
// Ported from Monica's trading simulator (simBenchmark.js + trading.js)
// Pine Script v6
//
// Displays Kelly-optimal position sizing, momentum entry signals,
// and stop/target exit signals directly on the chart.

//@version=6
indicator("Monica Kelly Momentum", overlay=true, max_labels_count=500)

// ---- Inputs ----------------------------------------------------------------

grp_kelly   = "Kelly Criterion"
grp_entry   = "Entry Signal (Momentum)"
grp_exit    = "Exit Signal"
grp_display = "Display"

i_equity      = input.float(10000.0, "Account Equity ($)",   minval=1.0,    group=grp_kelly)
i_kellyFrac   = input.float(0.25,    "Kelly Fraction",       minval=0.01, maxval=1.0, step=0.05, group=grp_kelly)
i_kellyCap    = input.float(0.10,    "Max Position Size (%)", minval=0.01, maxval=1.0, step=0.01, group=grp_kelly)
i_winRate     = input.float(0.55,    "Estimated Win Rate",   minval=0.01, maxval=0.99, step=0.01, group=grp_kelly)
i_rr          = input.float(2.94,    "Reward/Risk Ratio (5% target / 1.7% stop)", minval=0.1, step=0.1, group=grp_kelly)

i_smaFast     = input.int(10,    "Fast MA Length",          minval=2,     group=grp_entry)
i_smaSlow     = input.int(20,    "Slow MA Length",          minval=2,     group=grp_entry)
i_strength    = input.float(0.01, "Momentum Strength Threshold", minval=0.001, step=0.001, group=grp_entry)
i_volCap      = input.float(0.025, "Volatility Cap (stddev/SMA)", minval=0.001, step=0.005, group=grp_entry)
i_risingBars  = input.int(5,     "Min Rising Bars (of last 10)", minval=1, maxval=10, group=grp_entry)

i_stopPct     = input.float(1.7,  "Stop Loss %",    minval=0.1, step=0.1, group=grp_exit)
i_targetPct   = input.float(5.0,  "Take Profit %",  minval=0.1, step=0.1, group=grp_exit)
i_trailTrig   = input.float(2.0,  "Trailing Stop Trigger %", minval=0.1, step=0.1, group=grp_exit)
i_trailPct    = input.float(3.0,  "Trailing Stop Distance %", minval=0.1, step=0.1, group=grp_exit)

i_showTable   = input.bool(true,  "Show Info Table",     group=grp_display)
i_showBg      = input.bool(true,  "Background in Entry Zone", group=grp_display)

// ---- Kelly Criterion --------------------------------------------------------

// f = (b*p - q) / b
// b = reward/risk ratio, p = win probability, q = 1-p
kellyFull   = (i_rr * i_winRate - (1.0 - i_winRate)) / i_rr
kellyPct    = math.max(0.0, math.min(kellyFull * i_kellyFrac, i_kellyCap))
positionDollars = i_equity * kellyPct
recShares   = positionDollars / close
riskDollars = positionDollars * (i_stopPct / 100.0)

// ---- Moving Averages --------------------------------------------------------

smaFast = ta.sma(close, i_smaFast)
smaSlow = ta.sma(close, i_smaSlow)

// ---- Momentum Strength ------------------------------------------------------

strength     = (close - smaFast) / smaFast
prevStrength = (close[1] - smaFast[1]) / smaFast[1]

// ---- Volatility Filter ------------------------------------------------------
// stddev of last 10 bars normalized by SMA

volRaw  = ta.stdev(close, i_smaFast)
volNorm = volRaw / smaFast

// ---- Rising Bar Count -------------------------------------------------------
// Count how many of the last 10 bars closed higher than the prior bar

risingCount = 0
for i = 1 to 10
    if close[i - 1] > close[i]
        risingCount += 1

// ---- Entry Conditions -------------------------------------------------------

momentumOk   = strength >= i_strength
prevMomOk    = prevStrength > 0.0
volOk        = volNorm < i_volCap
risingOk     = risingCount >= i_risingBars
aboveSlowMA  = close > smaSlow
kellyPositive = kellyPct > 0.0

entrySignal = momentumOk and prevMomOk and volOk and risingOk and aboveSlowMA and kellyPositive

// ---- Exit Levels (from entry price proxy) -----------------------------------
// Use the close of the entry bar as a reference; in a real strategy the
// actual entry price would be used. Here we track the most recent entry bar.

var float entryPrice   = na
var bool  inPosition   = false
var float trailingStop = na

if entrySignal and not inPosition
    entryPrice   := close
    inPosition   := true
    trailingStop := close * (1.0 - i_stopPct / 100.0)

stopLevel   = inPosition ? entryPrice * (1.0 - i_stopPct / 100.0) : na
targetLevel = inPosition ? entryPrice * (1.0 + i_targetPct / 100.0) : na

// Update trailing stop
if inPosition
    pnlPct = (close - entryPrice) / entryPrice
    if pnlPct > i_trailTrig / 100.0
        newTrail = close * (1.0 - i_trailPct / 100.0)
        trailingStop := math.max(nz(trailingStop), newTrail)

effectiveStop = inPosition ? math.max(nz(stopLevel), nz(trailingStop)) : na

// Exit conditions
hitStop   = inPosition and low <= effectiveStop
hitTarget = inPosition and high >= targetLevel

exitSignal = hitStop or hitTarget

if exitSignal
    inPosition   := false
    entryPrice   := na
    trailingStop := na

// ---- Plots ------------------------------------------------------------------

plot(smaFast, "SMA Fast", color=color.new(color.blue, 40), linewidth=1)
plot(smaSlow, "SMA Slow", color=color.new(color.orange, 40), linewidth=1)
plot(inPosition ? effectiveStop : na, "Stop Level", color=color.new(color.red, 20), style=plot.style_linebr, linewidth=1)
plot(inPosition ? targetLevel : na, "Target Level", color=color.new(color.green, 20), style=plot.style_linebr, linewidth=1)

// Entry / exit markers
plotshape(entrySignal and not inPosition[1], "Entry", shape.triangleup, location.belowbar, color.new(color.green, 0), size=size.small)
plotshape(exitSignal, "Exit", shape.triangledown, location.abovebar, color.new(color.red, 0), size=size.small)

// Background tint in entry zone
bgcolor(i_showBg and entrySignal ? color.new(color.green, 92) : na)

// ---- Info Table -------------------------------------------------------------

if i_showTable and barstate.islast
    var table tbl = table.new(position.top_right, 2, 7, border_width=1)

    table.cell(tbl, 0, 0, "Monica Kelly", text_color=color.white, bgcolor=color.new(color.blue, 20), text_size=size.small)
    table.cell(tbl, 1, 0, "", bgcolor=color.new(color.blue, 20))

    table.cell(tbl, 0, 1, "Win Rate", text_color=color.gray, text_size=size.tiny)
    table.cell(tbl, 1, 1, str.tostring(i_winRate * 100, "#.#") + "%", text_color=color.white, text_size=size.tiny)

    table.cell(tbl, 0, 2, "Full Kelly", text_color=color.gray, text_size=size.tiny)
    table.cell(tbl, 1, 2, str.tostring(kellyFull * 100, "#.##") + "%", text_color=color.white, text_size=size.tiny)

    table.cell(tbl, 0, 3, "Fractional Kelly", text_color=color.gray, text_size=size.tiny)
    table.cell(tbl, 1, 3, str.tostring(kellyPct * 100, "#.##") + "%", text_color=kellyPct > 0 ? color.lime : color.red, text_size=size.tiny)

    table.cell(tbl, 0, 4, "Position $", text_color=color.gray, text_size=size.tiny)
    table.cell(tbl, 1, 4, "$" + str.tostring(positionDollars, "#,###.##"), text_color=color.white, text_size=size.tiny)

    table.cell(tbl, 0, 5, "Shares", text_color=color.gray, text_size=size.tiny)
    table.cell(tbl, 1, 5, str.tostring(recShares, "#,###.##"), text_color=color.white, text_size=size.tiny)

    table.cell(tbl, 0, 6, "Risk $", text_color=color.gray, text_size=size.tiny)
    table.cell(tbl, 1, 6, "$" + str.tostring(riskDollars, "#,###.##"), text_color=color.orange, text_size=size.tiny)
